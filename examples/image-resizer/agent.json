{
  "id": "image-resizer",
  "type": "code",
  "version": "0.1.0",
  "purpose": "Resize images maintaining aspect ratio, snapped to 64px, minimum 1MP area",
  "deterministic": {
    "pre_checks": [
      {
        "condition": "cabinet-exists(path=input/*.png) OR cabinet-exists(path=input/*.jpg)",
        "action": "halt",
        "message": "No input image found in cabinet at 'input/*.png' or 'input/*.jpg'"
      }
    ]
  },
  "code": {
    "entrypoint": "./index.ts",
    "timeout": 30000
  },
  "learning": {
    "channels": []
  },
  "visibility": {
    "expose": {
      "cabinet": [
        {
          "from": "output/*",
          "as": "results/"
        }
      ],
      "blackboard": [
        {
          "from": "task.output",
          "as": "resize.result"
        }
      ]
    }
  }
}
