{
  "id": "composition-analyzer",
  "type": "code",
  "version": "0.1.0",
  "purpose": "Pre-scan image edges at thumbnail resolution (≤1024px) to detect where important content lies",
  "deterministic": {
    "pre_checks": [
      {
        "condition": "cabinet-exists(path=input/path)",
        "action": "halt",
        "message": "No input path in cabinet"
      }
    ]
  },
  "code": {
    "entrypoint": "./index.ts",
    "timeout": 10000
  },
  "learning": {
    "channels": []
  }
}
