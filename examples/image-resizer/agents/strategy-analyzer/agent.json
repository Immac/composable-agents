{
  "id": "strategy-analyzer",
  "type": "llm",
  "version": "0.1.0",
  "purpose": "Choose contain vs cover based on edge scan data",
  "deterministic": {
    "pre_checks": [
      {
        "condition": "cabinet-exists(path=composition/analysis)",
        "action": "halt"
      }
    ],
    "post_processing": [
      {
        "condition": "NOT cabinet-exists(path=strategy/decision)",
        "action": "warn"
      }
    ]
  },
  "llm": {
    "prompt_template": "./analyze.md",
    "model": "opencode-go/deepseek4flash",
    "temperature": 0.1
  },
  "learning": {
    "channels": [
      {
        "type": "modify-prompt",
        "handler": "stage-for-review"
      }
    ]
  }
}
