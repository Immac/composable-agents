{
  "id": "story-writer",
  "type": "llm",
  "version": "0.1.0",
  "purpose": "Write narrative prose from a story concept in the cabinet",
  "deterministic": {
    "pre_checks": [
      {
        "condition": "cabinet-exists(path=story/draft)",
        "action": "skip-agent",
        "message": "Draft already exists — use revision-writer instead"
      }
    ]
  },
  "llm": {
    "temperature": 0.8,
    "max_tokens": 2048
  },
  "learning": {
    "channels": []
  }
}
